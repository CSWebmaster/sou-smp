// Firestore Security Rules

rules_version = '2';
service cloud.firestore {
  // Allow read access to public data (events, awards, members for display)
  match /databases/{database}/documents {
    
    // Public read access for frontend display
    match /events/{eventId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }
    
    match /awards/{awardId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }
    
    match /members/{memberId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }
    
    match /journey/{journeyId} {
      allow read: if true;
      allow write: if request.auth != null && isAdmin(request.auth.uid);
    }
    
    // Admin-only collections
    match /admin/{docId} {
      allow read, write: if request.auth != null && isAdmin(request.auth.uid);
    }
    
    // Utility functions
    function isAdmin(uid) {
      // Check if user is in the admins collection
      return get(/databases/$(database)/documents/admins/$(uid)).data.role == 'admin';
    }
  }
}